DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_ADMIN_USER_IDS=

# Optional. Leave empty to register global commands for every server where the bot is installed.
DISCORD_GUILD_ID=

COVAFLUX_API_BASE_URL=http://localhost:12145
COVAFLUX_ADMIN_USERNAME=admin
COVAFLUX_ADMIN_PASSWORD=<your-covaflux-admin-password>
TAILSCALE_LOGIN_SERVER=http://localhost

# Used to encrypt CovaFlux JWTs in data/bindings.json. Use a long random value.
DISCORD_BOT_SECRET=<use-a-long-random-secret>

DATA_DIR=./data

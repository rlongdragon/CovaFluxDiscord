{
  "name": "covaflux-discord",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "register": "node dist/register-commands.js",
    "pm2:start": "PM2_HOME=.pm2 pm2 start ecosystem.config.cjs",
    "pm2:restart": "PM2_HOME=.pm2 pm2 restart covaflux-discord",
    "pm2:stop": "PM2_HOME=.pm2 pm2 stop covaflux-discord",
    "pm2:logs": "PM2_HOME=.pm2 pm2 logs covaflux-discord",
    "pm2:status": "PM2_HOME=.pm2 pm2 status"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
